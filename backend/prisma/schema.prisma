generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Stage 2: Core auth foundation — User, Location, UserLocationRole.
// Stage 3: Master data — Category, Vendor, Uom, Goods, AuditLog.

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String
  isActive     Boolean  @default(true)
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  locationRoles UserLocationRole[]
  auditLogs     AuditLog[]
}

model Location {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles UserLocationRole[]
}

model UserLocationRole {
  id         String @id @default(uuid())
  userId     String
  locationId String
  role       Role

  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([userId, locationId])
}

enum Role {
  OPERATOR
  MANAGER
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Vendor {
  id          String   @id @default(uuid())
  name        String
  contactInfo String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Uom {
  id   String @id @default(uuid())
  code String @unique
  name String

  products Product[]
}

model Product {
  id         String   @id @default(uuid())
  sku        String   @unique
  name       String
  categoryId String
  vendorId   String
  uomId      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  vendor   Vendor   @relation(fields: [vendorId], references: [id])
  uom      Uom      @relation(fields: [uomId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  beforeValue Json?
  afterValue  Json?
  performedBy String
  timestamp   DateTime @default(now())

  user User @relation(fields: [performedBy], references: [id])
}
