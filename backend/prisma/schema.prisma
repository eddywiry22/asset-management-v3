generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Stage 2: Core auth foundation — User, Location, UserLocationRole.
// Stage 3: Master data — Category, Vendor, Uom, Goods, AuditLog.

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String
  isActive     Boolean  @default(true)
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  locationRoles         UserLocationRole[]
  auditLogs             AuditLog[]
  adjustmentsCreated    StockAdjustmentRequest[] @relation("AdjustmentCreatedBy")
  adjustmentsApproved   StockAdjustmentRequest[] @relation("AdjustmentApprovedBy")
  adjustmentsFinalized  StockAdjustmentRequest[] @relation("AdjustmentFinalizedBy")
  adjustmentsCancelled  StockAdjustmentRequest[] @relation("AdjustmentCancelledBy")
  adjustmentsRejected   StockAdjustmentRequest[] @relation("AdjustmentRejectedBy")
  transfersCreated              StockTransferRequest[] @relation("TransferCreatedBy")
  transfersOriginApproved       StockTransferRequest[] @relation("TransferOriginApprovedBy")
  transfersDestinationApproved  StockTransferRequest[] @relation("TransferDestinationApprovedBy")
  transfersCancelled            StockTransferRequest[] @relation("TransferCancelledBy")
  transfersRejected             StockTransferRequest[] @relation("TransferRejectedBy")
}

model Location {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles              UserLocationRole[]
  stockBalances          StockBalance[]
  stockLedgers           StockLedger[]
  adjustmentItems        StockAdjustmentItem[]
  transfersAsSource      StockTransferRequest[] @relation("TransferSourceLocation")
  transfersAsDestination StockTransferRequest[] @relation("TransferDestinationLocation")
  stockReservations      StockReservation[]
  productLocations       ProductLocation[]
}

model UserLocationRole {
  id         String @id @default(uuid())
  userId     String
  locationId String
  role       Role

  user     User     @relation(fields: [userId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([userId, locationId])
}

enum Role {
  OPERATOR
  MANAGER
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Vendor {
  id          String   @id @default(uuid())
  name        String
  contactInfo String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Uom {
  id   String @id @default(uuid())
  code String @unique
  name String

  products Product[]
}

model Product {
  id         String   @id @default(uuid())
  sku        String   @unique
  name       String
  categoryId String
  vendorId   String
  uomId      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  uom           Uom            @relation(fields: [uomId], references: [id])
  stockBalances    StockBalance[]
  stockLedgers     StockLedger[]
  adjustmentItems  StockAdjustmentItem[]
  transferItems    StockTransferItem[]
  stockReservations StockReservation[]
  productLocations  ProductLocation[]
}

// ---------------------------------------------------------------------------
// Stage 8: Product-Location mapping
// ---------------------------------------------------------------------------

model ProductLocation {
  id         String   @id @default(uuid())
  productId  String
  locationId String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
}

// ---------------------------------------------------------------------------
// Stage 4: Stock Balances & Ledger
// ---------------------------------------------------------------------------

model StockBalance {
  id          String   @id @default(uuid())
  productId   String
  locationId  String
  onHandQty   Decimal  @default(0) @db.Decimal(15, 4)
  reservedQty Decimal  @default(0) @db.Decimal(15, 4)
  updatedAt   DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
  @@index([locationId])
}

// ---------------------------------------------------------------------------
// Stage 7: Stock Reservation System
// ---------------------------------------------------------------------------

enum ReservationSourceType {
  TRANSFER
  ADJUSTMENT
}

enum ReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

model StockReservation {
  id           String                @id @default(uuid())
  productId    String
  locationId   String
  qty          Decimal               @db.Decimal(15, 4)
  sourceType   ReservationSourceType
  sourceId     String
  sourceItemId String
  status       ReservationStatus     @default(ACTIVE)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([productId, locationId])
  @@index([sourceType, sourceId])
}

model StockLedger {
  id           String           @id @default(uuid())
  productId    String
  locationId   String
  changeQty    Decimal          @db.Decimal(15, 4)
  balanceAfter Decimal          @db.Decimal(15, 4)
  sourceType   LedgerSourceType
  sourceId     String
  createdAt    DateTime         @default(now())

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([productId, locationId, createdAt])
  @@index([locationId, createdAt])
}

enum LedgerSourceType {
  ADJUSTMENT
  MOVEMENT_IN
  MOVEMENT_OUT
  SEED
  TRANSFER_IN
  TRANSFER_OUT
}

// ---------------------------------------------------------------------------
// Stage 5: Stock Adjustment Requests
// ---------------------------------------------------------------------------

enum AdjustmentRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  FINALIZED
  CANCELLED
}

model StockAdjustmentRequest {
  id            String                   @id @default(uuid())
  requestNumber String                   @unique
  status        AdjustmentRequestStatus  @default(DRAFT)
  notes              String?  @db.Text
  createdById        String
  approvedById       String?
  finalizedById      String?
  cancelledById      String?
  rejectedById       String?
  approvedAt         DateTime?
  finalizedAt        DateTime?
  cancelledAt        DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?  @db.Text
  cancellationReason String?  @db.Text
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  createdBy   User                   @relation("AdjustmentCreatedBy",   fields: [createdById],   references: [id])
  approvedBy  User?                  @relation("AdjustmentApprovedBy",  fields: [approvedById],  references: [id])
  finalizedBy User?                  @relation("AdjustmentFinalizedBy", fields: [finalizedById], references: [id])
  cancelledBy User?                  @relation("AdjustmentCancelledBy", fields: [cancelledById], references: [id])
  rejectedBy  User?                  @relation("AdjustmentRejectedBy",  fields: [rejectedById],  references: [id])
  items       StockAdjustmentItem[]

  @@index([status])
  @@index([createdById])
}

model StockAdjustmentItem {
  id        String   @id @default(uuid())
  requestId String
  productId String
  locationId String
  qtyChange Decimal  @db.Decimal(15, 4)
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  request  StockAdjustmentRequest @relation(fields: [requestId], references: [id])
  product  Product                @relation(fields: [productId], references: [id])
  location Location               @relation(fields: [locationId], references: [id])

  @@index([requestId])
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  beforeValue Json?
  afterValue  Json?
  performedBy String
  timestamp   DateTime @default(now())

  user User @relation(fields: [performedBy], references: [id])
}

// ---------------------------------------------------------------------------
// Stage 6: Stock Transfer Requests
// ---------------------------------------------------------------------------

enum TransferRequestStatus {
  DRAFT
  SUBMITTED
  ORIGIN_MANAGER_APPROVED
  DESTINATION_OPERATOR_APPROVED
  READY_TO_FINALIZE
  FINALIZED
  CANCELLED
  REJECTED
}

model StockTransferRequest {
  id                      String                @id @default(uuid())
  requestNumber           String                @unique
  status                  TransferRequestStatus @default(DRAFT)
  sourceLocationId        String
  destinationLocationId   String
  notes                   String?               @db.Text
  createdById             String
  submittedAt             DateTime?
  originApprovedById      String?
  originApprovedAt        DateTime?
  destinationApprovedById String?
  destinationApprovedAt   DateTime?
  finalizedAt             DateTime?
  cancelledById           String?
  cancelledAt             DateTime?
  cancellationReason      String?               @db.Text
  rejectedById            String?
  rejectedAt              DateTime?
  rejectionReason         String?               @db.Text
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  createdBy             User                @relation("TransferCreatedBy",             fields: [createdById],             references: [id])
  originApprovedBy      User?               @relation("TransferOriginApprovedBy",      fields: [originApprovedById],      references: [id])
  destinationApprovedBy User?               @relation("TransferDestinationApprovedBy", fields: [destinationApprovedById], references: [id])
  cancelledBy           User?               @relation("TransferCancelledBy",           fields: [cancelledById],           references: [id])
  rejectedBy            User?               @relation("TransferRejectedBy",            fields: [rejectedById],            references: [id])
  sourceLocation        Location            @relation("TransferSourceLocation",        fields: [sourceLocationId],        references: [id])
  destinationLocation   Location            @relation("TransferDestinationLocation",   fields: [destinationLocationId],   references: [id])
  items                 StockTransferItem[]

  @@index([status])
  @@index([createdById])
  @@index([sourceLocationId])
  @@index([destinationLocationId])
}

model StockTransferItem {
  id        String   @id @default(uuid())
  requestId String
  productId String
  qty       Decimal  @db.Decimal(15, 4)
  createdAt DateTime @default(now())

  request StockTransferRequest @relation(fields: [requestId], references: [id])
  product Product              @relation(fields: [productId], references: [id])

  @@index([requestId])
}
